rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper: Is the user an admin?
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email))
      );
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !getUserData().isMuted && !getUserData().isBanned;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.senderId || 
        isAdmin()
      );
      allow delete: if isAdmin(); // We prefer soft-delete, but admin can hard-delete
    }

    // Typing Collection
    match /typing/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Admin Emails (Read-only for admins)
    match /admin_emails/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default: Allow all other collections for a limited time (as per existing rules)
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 5, 25);
    }
  }
}
